# OpenSky Network OAuth2 client credentials
# Create an API client at https://opensky-network.org/ → Account → API Clients
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# aisstream.io API key (required for ship data)
# Register at https://aisstream.io/
AISSTREAM_API_KEY=your_key_here

# Port the FastAPI server listens on
PORT=8000
